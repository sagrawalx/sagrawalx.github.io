\newlabel{circle-projection}{{3.2.5}{164}{Given a point $a \in U = S^1 \setminus \{(0,1)\}$, we draw a line connecting $a$ to $(0,1)$, indicated in red. The point where that line intersects the line $y = -1$ (in black) is sometimes called the ``projection'' of $a$ from $(0,1)$ onto $\R \times \{-1\}$. The $x$-coordinate of this point is $\phi (a)$}{figure.651}{}}
