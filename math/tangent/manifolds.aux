\@writefile{lof}{\defcounter {refsection}{0}\relax }\@writefile{lof}{\contentsline {figure}{\numberline {3.2.21}{\ignorespaces Suppose $X$ is a manifold (depicted above as an amorphous blob) and $S$ is a subset (depicted above as a squiggly line passing through the blob). Then $S$ is defined to be a \emph  {submanifold} of $X$ if $S$ can be covered by charts $(U, \varphi )$ such that, under $\varphi $, the set $S \cap U$ corresponds to a coordinate hyperplane in $\mathbb  {R}^n$. In the picture above, the map $\varphi : U \to \mathbb  {R}^2$ pulls the squiggle $S \cap U$ taut onto the $x$-axis inside $\mathbb  {R}^2$. }}{170}{figure.679}}
\newlabel{submanifold-definition-picture}{{3.2.21}{170}{Suppose $X$ is a manifold (depicted above as an amorphous blob) and $S$ is a subset (depicted above as a squiggly line passing through the blob). Then $S$ is defined to be a \emph {submanifold} of $X$ if $S$ can be covered by charts $(U, \phi )$ such that, under $\phi $, the set $S \cap U$ corresponds to a coordinate hyperplane in $\R ^n$. In the picture above, the map $\phi : U \to \R ^2$ pulls the squiggle $S \cap U$ taut onto the $x$-axis inside $\R ^2$}{figure.679}{}}
\newlabel{submanifold-definition-picture@cref}{{[figure][21][3]3.2.21}{[1][169][]170}}
