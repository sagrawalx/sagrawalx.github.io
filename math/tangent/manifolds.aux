\@writefile{lof}{\defcounter {refsection}{0}\relax }\@writefile{lof}{\contentsline {figure}{\numberline {3.2.26}{\ignorespaces If $U = \{(x,y) : x > 0\}$ is the right half of the plane and $\varphi : U \to \mathbb  {R}^2$ is given by $\varphi (x,y) = (x^2 + y^2 - 1, x)$, then $(U, \varphi )$ is a chart on $\mathbb  {R}^2$ that transforms the picture on the left into the picture on the right. The vertical axis on the left turns into the parabola on the right. The top half of the circle on the left turns into the horizontal line segment on right. The vertical axis on the left stays remains the vertical axis on the right.}}{172}{figure.688}}
\newlabel{circle-submanifold-picture}{{3.2.26}{172}{If $U = \{(x,y) : x > 0\}$ is the right half of the plane and $\phi : U \to \R ^2$ is given by $\phi (x,y) = (x^2 + y^2 - 1, x)$, then $(U, \phi )$ is a chart on $\R ^2$ that transforms the picture on the left into the picture on the right. The vertical axis on the left turns into the parabola on the right. The top half of the circle on the left turns into the horizontal line segment on right. The vertical axis on the left stays remains the vertical axis on the right}{figure.688}{}}
\newlabel{circle-submanifold-picture@cref}{{[figure][26][3]3.2.26}{[1][171][]172}}
